u1089\'f1\u1080\'e8\u1080\'e8\u8220\'93. \u1042\'c2\u1085\'ed\u1091\'f3\u1090\'f2\u1088\'f0\u1080\'e8 \u1087\'ef\u1091\'f3\u1079\'e7\u1099\'fb\u1088\'f0\u1103\'ff \u8212\'97 \u1080\'e8\u1082\'ea\u1086\'ee\u1085\'ed\u1082\'ea\u1080\'e8: \u1091\'f3\u1095\'f7\u1077\'e5\u1085\'ed\u1080\'e8\u1082\'ea \u1089\'f1 \u1087\'ef\u1077\'e5\u1088\'f0\u1089\'f1\u1086\'ee\u1085\'ed\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee\u1081\'e9 \u1090\'f2\u1088\'f0\u1072\'e0\u1077\'e5\u1082\'ea\u1090\'f2\u1086\'ee\u1088\'f0\u1080\'e8\u1077\'e5\u1081\'e9, \u1091\'f3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc \u1089\'f1 \u1048\'c8\u1048\'c8-\u1072\'e0\u1089\'f1\u1089\'f1\u1080\'e8\u1089\'f1\u1090\'f2\u1077\'e5\u1085\'ed\u1090\'f2\u1086\'ee\u1084\'ec, \u1076\'e4\u1072\'e0\u1096\'f8\u1073\'e1\u1086\'ee\u1088\'f0\u1076\'e4 \u1072\'e0\u1076\'e4\u1084\'ec\u1080\'e8\u1085\'ed\u1080\'e8\u1089\'f1\u1090\'f2\u1088\'f0\u1072\'e0\u1094\'f6\u1080\'e8\u1080\'e8, \u1074\'e2\u1080\'e8\u1088\'f0\u1090\'f2\u1091\'f3\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1072\'e0\u1103\'ff \u1083\'eb\u1072\'e0\u1073\'e1\u1086\'ee\u1088\'f0\u1072\'e0\u1090\'f2\u1086\'ee\u1088\'f0\u1080\'e8\u1103\'ff. \u1055\'cf\u1091\'f3\u1079\'e7\u1099\'fb\u1088\'f0\u1100\'fc \u1089\'f1\u1086\'ee\u1077\'e5\u1076\'e4\u1080\'e8\u1085\'ed\u1105\'b8\u1085\'ed \u1090\'f2\u1086\'ee\u1083\'eb\u1089\'f1\u1090\'f2\u1099\'fb\u1084\'ec\u1080\'e8 \u1089\'f1\u1090\'f2\u1088\'f0\u1077\'e5\u1083\'eb\u1082\'ea\u1072\'e0\u1084\'ec\u1080\'e8 \u1089\'f1 \u1089\'f1\u1077\'e5\u1082\'ea\u1090\'f2\u1086\'ee\u1088\'f0\u1072\'e0\u1084\'ec\u1080\'e8: \u1101\'fd\u1082\'ea\u1086\'ee\u1085\'ed\u1086\'ee\u1084\'ec\u1080\'e8\u1082\'ea\u1072\'e0, \u1053\'cd\u1058\'d2\u1048\'c8, \u1079\'e7\u1076\'e4\u1088\'f0\u1072\'e0\u1074\'e2\u1086\'ee\u1086\'ee\u1093\'f5\u1088\'f0\u1072\'e0\u1085\'ed\u1077\'e5\u1085\'ed\u1080\'e8\u1077\'e5, \u1085\'ed\u1072\'e0\u1091\'f3\u1082\'ea\u1072\'e0, \u1090\'f2\u1074\'e2\u1086\'ee\u1088\'f0\u1095\'f7\u1077\'e5\u1089\'f1\u1082\'ea\u1080\'e8\u1077\'e5 \u1080\'e8\u1085\'ed\u1076\'e4\u1091\'f3\u1089\'f1\u1090\'f2\u1088\'f0\u1080\'e8\u1080\'e8. \u1042\'c2\u1085\'ed\u1080\'e8\u1079\'e7\u1091\'f3 \u1087\'ef\u1086\'ee\u1076\'e4\u1087\'ef\u1080\'e8\u1089\'f1\u1100\'fc \u8222\'84\u1055\'cf\u1077\'e5\u1088\'f0\u1089\'f1\u1086\'ee\u1085\'ed\u1072\'e0\u1083\'eb\u1080\'e8\u1079\'e7\u1072\'e0\u1094\'f6\u1080\'e8\u1103\'ff + \u1089\'f1\u1072\'e0\u1084\'ec\u1086\'ee\u1088\'f0\u1077\'e5\u1072\'e0\u1083\'eb\u1080\'e8\u1079\'e7\u1072\'e0\u1094\'f6\u1080\'e8\u1103\'ff\u8220\'93. \u1060\'d4\u1086\'ee\u1085\'ed \u1089\'f1\u1074\'e2\u1077\'e5\u1090\'f2\u1083\'eb\u1099\'fb\u1081\'e9, \u1092\'f4\u1091\'f3\u1090\'f2\u1091\'f3\u1088\'f0\u1080\'e8\u1089\'f1\u1090\'f2\u1080\'e8\u1095\'f7\u1085\'ed\u1099\'fb\u1081\'e9, \u1095\'f7\u1080\'e8\u1089\'f1\u1090\'f2\u1099\'fb\u1081\'e9, \u1074\'e2\u1077\'e5\u1082\'ea\u1090\'f2\u1086\'ee\u1088\'f0\u1085\'ed\u1099\'fb\u1081\'e9 \u1089\'f1\u1090\'f2\u1080\'e8\u1083\'eb\u1100\'fc, \u1082\'ea\u1072\'e0\u1082\'ea \u1085\'ed\u1072\'e0 \u1086\'ee\u1092\'f4\u1080\'e8\u1094\'f6\u1080\'e8\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1099\'fb\u1093\'f5 \u1087\'ef\u1088\'f0\u1077\'e5\u1079\'e7\u1077\'e5\u1085\'ed\u1090\'f2\u1072\'e0\u1094\'f6\u1080\'e8\u1103\'ff\u1093\'f5 \u1055\'cf\u1088\'f0\u1072\'e0\u1074\'e2\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc\u1089\'f1\u1090\'f2\u1074\'e2\u1072\'e0 \u1056\'d0\u1060\'d4. \u1058\'d2\u1077\'e5\u1082\'ea\u1089\'f1\u1090\'f2 \u1085\'ed\u1072\'e0 \u1088\'f0\u1091\'f3\u1089\'f1\u1089\'f1\u1082\'ea\u1086\'ee\u1084\'ec, \u1095\'f7\u1080\'e8\u1090\'f2\u1072\'e0\u1077\'e5\u1084\'ec\u1099\'fb\u1081\'e9.\u187\'bb}
