\par \pard\plain \s0\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af6\afs24\alang1081\ltrch\hich\af3\afs24\alang1049\dbch\af8\langfe2052\loch\f3\fs24\lang1049\ql\ltrpar{
\u1045\'c5\u1089\'f1\u1083\'eb\u1080\'e8 \u1074\'e2\u1089\'f1\u1105\'b8 \u1089\'f1\u1076\'e4\u1077\'e5\u1083\'eb\u1072\'e0\u1090\'f2\u1100\'fc \u1087\'ef\u1088\'f0\u1072\'e0\u1074\'e2\u1080\'e8\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee, \u1075\'e3\u1080\'e8\u1084\'ec\u1085\'ed\u1072\'e0\u1079\'e7\u1080\'e8\u1103\'ff \u1089\'f1\u1090\'f2\u1072\'e0\u1085\'ed\u1077\'e5\u1090\'f2 \u1082\'ea\u1088\'f0\u1077\'e5\u1087\'ef\u1095\'f7\u1077\'e5, \u1088\'f0\u1086\'ee\u1076\'e4\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1080\'e8 \u1087\'ef\u1086\'ee\u1083\'eb\u1091\'f3\u1095\'f7\u1072\'e0\u1090\'f2 \u1091\'f3\u1074\'e2\u1077\'e5\u1088\'f0\u1077\'e5\u1085\'ed\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1100\'fc \u1074\'e2 \u1073\'e1\u1091\'f3\u1076\'e4\u1091\'f3\u1097\'f9\u1077\'e5\u1084\'ec \u1089\'f1\u1074\'e2\u1086\'ee\u1080\'e8\u1093\'f5 \u1076\'e4\u1077\'e5\u1090\'f2\u1077\'e5\u1081\'e9, \u1072\'e0 \u1084\'ec\u1099\'fb \u8212\'97 \u1087\'ef\u1088\'f0\u1086\'ee\u1089\'f1\u1090\'f2\u1088\'f0\u1072\'e0\u1085\'ed\u1089\'f1\u1090\'f2\u1074\'e2\u1086\'ee \u1076\'e4\u1083\'eb\u1103\'ff \u1085\'ed\u1072\'e0\u1089\'f1\u1090\'f2\u1086\'ee\u1103\'ff\u1097\'f9\u1077\'e5\u1075\'e3\u1086\'ee \u1090\'f2\u1074\'e2\u1086\'ee\u1088\'f0\u1095\'f7\u1077\'e5\u1089\'f1\u1090\'f2\u1074\'e2\u1072\'e0 \u1080\'e8 \u1088\'f0\u1086\'ee\u1089\'f1\u1090\'f2\u1072\'e0.  }
