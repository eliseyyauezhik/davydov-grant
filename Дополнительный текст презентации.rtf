\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1042\'c2 \u1089\'f1\u1080\'e8\u1089\'f1\u1090\'f2\u1077\'e5\u1084\'ec\u1077\'e5 \u1088\'f0\u1072\'e0\u1079\'e7\u1074\'e2\u1080\'e8\u1074\'e2\u1072\'e0\u1102\'fe\u1097\'f9\u1077\'e5\u1075\'e3\u1086\'ee \u1086\'ee\u1073\'e1\u1091\'f3\u1095\'f7\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff \u1069\'dd\u1083\'eb\u1100\'fc\u1082\'ea\u1086\'ee\u1085\'ed\u1080\'e8\u1085\'ed\u1072\'e0\u8211\'96\u1044\'c4\u1072\'e0\u1074\'e2\u1099\'fb\u1076\'e4\u1086\'ee\u1074\'e2\u1072\'e0 \u1101\'fd\u1090\'f2\u1086\'ee \u1086\'ee\u1089\'f1\u1086\'ee\u1073\'e1\u1077\'e5\u1085\'ed\u1085\'ed\u1086\'ee \u1103\'ff\u1088\'f0\u1082\'ea\u1086\'ee \u1074\'e2\u1080\'e8\u1076\'e4\u1085\'ed\u1086\'ee \u1091\'f3\u1078\'e6\u1077\'e5 \u1089\'f1\u1077\'e5\u1081\'e9\u1095\'f7\u1072\'e0\u1089\'f1: }
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1091\'f3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc \u1085\'ed\u1080\'e8\u1082\'ea\u1086\'ee\u1075\'e3\u1076\'e4\u1072\'e0 \u1085\'ed\u1077\'e5 \u1073\'e1\u1099\'fb\u1083\'eb \u171\'ab\u1090\'f2\u1088\'f0\u1072\'e0\u1085\'ed\u1089\'f1\u1083\'eb\u1103\'ff\u1090\'f2\u1086\'ee\u1088\'f0\u1086\'ee\u1084\'ec \u1079\'e7\u1085\'ed\u1072\'e0\u1085\'ed\u1080\'e8\u1081\'e9\u187\'bb. \u1054\'ce\u1085\'ed \u1073\'e1\u1099\'fb\u1083\'eb \u1086\'ee\u1088\'f0\u1075\'e3\u1072\'e0\u1085\'ed\u1080\'e8\u1079\'e7\u1072\'e0\u1090\'f2\u1086\'ee\u1088\'f0\u1086\'ee\u1084\'ec \u1091\'f3\u1095\'f7\u1077\'e5\u1073\'e1\u1085\'ed\u1086\'ee\u1081\'e9 \u1076\'e4\u1077\'e5\u1103\'ff\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1080\'e8, \u1074\'e2 \u1082\'ea\u1086\'ee\u1090\'f2\u1086\'ee\u1088\'f0\u1086\'ee\u1081\'e9 \u1088\'f0\u1077\'e5\u1073\'e1\u1105\'b8\u1085\'ed\u1086\'ee\u1082\'ea \u1089\'f1\u1072\'e0\u1084\'ec \u1089\'f1\u1090\'f2\u1072\'e0\u1085\'ed\u1086\'ee\u1074\'e2\u1080\'e8\u1090\'f2\u1089\'f1\u1103\'ff \u1089\'f1\u1091\'f3\u1073\'e1\u1098\'fa\u1077\'e5\u1082\'ea\u1090\'f2\u1086\'ee\u1084\'ec. }
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1048\'c8\u1048\'c8 \u1087\'ef\u1088\'f0\u1086\'ee\u1089\'f1\u1090\'f2\u1086\'ee \u1076\'e4\u1086\'ee\u1074\'e2\u1086\'ee\u1076\'e4\u1080\'e8\u1090\'f2 \u1101\'fd\u1090\'f2\u1091\'f3 \u1083\'eb\u1086\'ee\u1075\'e3\u1080\'e8\u1082\'ea\u1091\'f3 \u1076\'e4\u1086\'ee \u1083\'eb\u1086\'ee\u1075\'e3\u1080\'e8\u1095\'f7\u1077\'e5\u1089\'f1\u1082\'ea\u1086\'ee\u1075\'e3\u1086\'ee \u1082\'ea\u1086\'ee\u1085\'ed\u1094\'f6\u1072\'e0: \u1086\'ee\u1085\'ed \u1073\'e1\u1077\'e5\u1088\'f0\u1105\'b8\u1090\'f2 \u1085\'ed\u1072\'e0 \u1089\'f1\u1077\'e5\u1073\'e1\u1103\'ff \u1074\'e2\u1077\'e5\u1089\'f1\u1100\'fc \u171\'ab\u1084\'ec\u1072\'e0\u1090\'f2\u1077\'e5\u1088\'f0\u1080\'e8\u1072\'e0\u1083\'eb\u187\'bb, \u1072\'e0 \u1091\'f3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc \u1086\'ee\u1089\'f1\u1090\'f2\u1072\'e0\u1105\'b8\u1090\'f2\u1089\'f1\u1103\'ff \u1095\'f7\u1080\'e8\u1089\'f1\u1090\'f2\u1099\'fb\u1084\'ec \u1092\'f4\u1072\'e0\u1089\'f1\u1080\'e8\u1083\'eb\u1080\'e8\u1090\'f2\u1072\'e0\u1090\'f2\u1086\'ee\u1088\'f0\u1086\'ee\u1084\'ec \u1088\'f0\u1072\'e0\u1079\'e7\u1074\'e2\u1080\'e8\u1090\'f2\u1080\'e8\u1103\'ff \u1084\'ec\u1099\'fb\u1096\'f8\u1083\'eb\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff \u1080\'e8 \u1083\'eb\u1080\'e8\u1095\'f7\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1080\'e8.}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar

\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1055\'cf\u1086\'ee\u1101\'fd\u1090\'f2\u1086\'ee\u1084\'ec\u1091\'f3 \u1089\'f1\u1091\'f3\u1097\'f9\u1077\'e5\u1089\'f1\u1090\'f2\u1074\'e2\u1091\'f3\u1102\'fe\u1097\'f9\u1080\'e8\u1081\'e9 \u1048\'c8\u1048\'c8-\u1090\'f2\u1100\'fc\u1102\'fe\u1090\'f2\u1086\'ee\u1088\'f0 + \u1075\'e3\u1080\'e8\u1084\'ec\u1085\'ed\u1072\'e0\u1079\'e7\u1080\'e8\u1103\'ff \u1044\'c4\u1072\'e0\u1074\'e2\u1099\'fb\u1076\'e4\u1086\'ee\u1074\'e2\u1072\'e0 \u8212\'97 \u1101\'fd\u1090\'f2\u1086\'ee \u1085\'ed\u1077\'e5 \u1087\'ef\u1088\'f0\u1086\'ee\u1089\'f1\u1090\'f2\u1086\'ee \u171\'ab\u1077\'e5\u1097\'f9\u1105\'b8 \u1086\'ee\u1076\'e4\u1080\'e8\u1085\'ed \u1087\'ef\u1080\'e8\u1083\'eb\u1086\'ee\u1090\'f2\u187\'bb. }
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1069\'dd\u1090\'f2\u1086\'ee \u1080\'e8\u1076\'e4\u1077\'e5\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1072\'e0\u1103\'ff \u1101\'fd\u1082\'ea\u1089\'f1\u1087\'ef\u1077\'e5\u1088\'f0\u1080\'e8\u1084\'ec\u1077\'e5\u1085\'ed\u1090\'f2\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1072\'e0\u1103\'ff \u1087\'ef\u1083\'eb\u1086\'ee\u1097\'f9\u1072\'e0\u1076\'e4\u1082\'ea\u1072\'e0 \u1076\'e4\u1083\'eb\u1103\'ff \u1084\'ec\u1086\'ee\u1076\'e4\u1077\'e5\u1083\'eb\u1080\'e8 \u1091\'f3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1103\'ff 2030 \u1075\'e3\u1086\'ee\u1076\'e4\u1072\'e0.}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar

\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
### \u1050\'ca\u1072\'e0\u1082\'ea \u1101\'fd\u1090\'f2\u1086\'ee \u1087\'ef\u1088\'f0\u1077\'e5\u1074\'e2\u1088\'f0\u1072\'e0\u1090\'f2\u1080\'e8\u1090\'f2\u1100\'fc \u1074\'e2 \u1075\'e3\u1088\'f0\u1072\'e0\u1085\'ed\u1090\'f2\u1086\'ee\u1074\'e2\u1091\'f3\u1102\'fe \u1090\'f2\u1077\'e5\u1084\'ec\u1091\'f3 (\u1075\'e3\u1086\'ee\u1090\'f2\u1086\'ee\u1074\'e2\u1099\'fb\u1077\'e5 \u1092\'f4\u1086\'ee\u1088\'f0\u1084\'ec\u1091\'f3\u1083\'eb\u1080\'e8\u1088\'f0\u1086\'ee\u1074\'e2\u1082\'ea\u1080\'e8 \u1087\'ef\u1086\'ee\u1076\'e4 \u1074\'e2\u1072\'e0\u1096\'f8 \u1073\'e1\u1102\'fe\u1076\'e4\u1078\'e6\u1077\'e5\u1090\'f2 1 \u1084\'ec\u1083\'eb\u1085\'ed \u1080\'e8 \u1086\'ee\u1076\'e4\u1085\'ed\u1091\'f3 \u1096\'f8\u1082\'ea\u1086\'ee\u1083\'eb\u1091\'f3)}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar

\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1058\'d2\u1077\'e5\u1084\'ec\u1072\'e0 \u8470\'b9 1 (\u1089\'f1\u1072\'e0\u1084\'ec\u1072\'e0\u1103\'ff \u1089\'f1\u1080\'e8\u1083\'eb\u1100\'fc\u1085\'ed\u1072\'e0\u1103\'ff \u1089\'f1\u1077\'e5\u1081\'e9\u1095\'f7\u1072\'e0\u1089\'f1): }
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u171\'ab\u1059\'d3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc \u1082\'ea\u1072\'e0\u1082\'ea \u1092\'f4\u1072\'e0\u1089\'f1\u1080\'e8\u1083\'eb\u1080\'e8\u1090\'f2\u1072\'e0\u1090\'f2\u1086\'ee\u1088\'f0 \u1090\'f2\u1077\'e5\u1086\'ee\u1088\'f0\u1077\'e5\u1090\'f2\u1080\'e8\u1095\'f7\u1077\'e5\u1089\'f1\u1082\'ea\u1086\'ee\u1075\'e3\u1086\'ee \u1084\'ec\u1099\'fb\u1096\'f8\u1083\'eb\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff \u1074\'e2 \u1091\'f3\u1089\'f1\u1083\'eb\u1086\'ee\u1074\'e2\u1080\'e8\u1103\'ff\u1093\'f5 \u1087\'ef\u1086\'ee\u1083\'eb\u1085\'ed\u1086\'ee\u1081\'e9 \u1080\'e8\u1085\'ed\u1092\'f4\u1086\'ee\u1088\'f0\u1084\'ec\u1072\'e0\u1094\'f6\u1080\'e8\u1086\'ee\u1085\'ed\u1085\'ed\u1086\'ee\u1081\'e9 \u1087\'ef\u1086\'ee\u1076\'e4\u1076\'e4\u1077\'e5\u1088\'f0\u1078\'e6\u1082\'ea\u1080\'e8 \u1048\'c8\u1048\'c8: \u1072\'e0\u1087\'ef\u1088\'f0\u1086\'ee\u1073\'e1\u1072\'e0\u1094\'f6\u1080\'e8\u1103\'ff \u1084\'ec\u1086\'ee\u1076\'e4\u1077\'e5\u1083\'eb\u1080\'e8 \u1074\'e2 \u1089\'f1\u1080\'e8\u1089\'f1\u1090\'f2\u1077\'e5\u1084\'ec\u1077\'e5 \u1088\'f0\u1072\'e0\u1079\'e7\u1074\'e2\u1080\'e8\u1074\'e2\u1072\'e0\u1102\'fe\u1097\'f9\u1077\'e5\u1075\'e3\u1086\'ee \u1086\'ee\u1073\'e1\u1091\'f3\u1095\'f7\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff \u1042\'c2.\u1042\'c2. \u1044\'c4\u1072\'e0\u1074\'e2\u1099\'fb\u1076\'e4\u1086\'ee\u1074\'e2\u1072\'e0\u187\'bb}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar

\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1058\'d2\u1077\'e5\u1084\'ec\u1072\'e0 \u8470\'b9 2 (\u1073\'e1\u1086\'ee\u1083\'eb\u1077\'e5\u1077\'e5 \u1087\'ef\u1088\'f0\u1080\'e8\u1082\'ea\u1083\'eb\u1072\'e0\u1076\'e4\u1085\'ed\u1072\'e0\u1103\'ff): }
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u171\'ab\u1048\'c8\u1048\'c8-\u1090\'f2\u1100\'fc\u1102\'fe\u1090\'f2\u1086\'ee\u1088\'f0 \u1082\'ea\u1072\'e0\u1082\'ea \u8220\'93\u1080\'e8\u1085\'ed\u1092\'f4\u1086\'ee\u1088\'f0\u1084\'ec\u1072\'e0\u1094\'f6\u1080\'e8\u1086\'ee\u1085\'ed\u1085\'ed\u1099\'fb\u1081\'e9 \u1089\'f1\u1082\'ea\u1077\'e5\u1083\'eb\u1077\'e5\u1090\'f2\u8221\'94 \u1091\'f3\u1088\'f0\u1086\'ee\u1082\'ea\u1072\'e0: \u1088\'f0\u1072\'e0\u1079\'e7\u1088\'f0\u1072\'e0\u1073\'e1\u1086\'ee\u1090\'f2\u1082\'ea\u1072\'e0 \u1080\'e8 \u1072\'e0\u1087\'ef\u1088\'f0\u1086\'ee\u1073\'e1\u1072\'e0\u1094\'f6\u1080\'e8\u1103\'ff 40 \u1089\'f1\u1094\'f6\u1077\'e5\u1085\'ed\u1072\'e0\u1088\'f0\u1080\'e8\u1077\'e5\u1074\'e2, \u1075\'e3\u1076\'e4\u1077\'e5 \u1091\'f3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc \u1086\'ee\u1089\'f1\u1074\'e2\u1086\'ee\u1073\'e1\u1086\'ee\u1078\'e6\u1076\'e4\u1105\'b8\u1085\'ed \u1086\'ee\u1090\'f2 \u1086\'ee\u1073\'e1\u1088\'f0\u1072\'e0\u1073\'e1\u1086\'ee\u1090\'f2\u1082\'ea\u1080\'e8 \u1080\'e8\u1085\'ed\u1092\'f4\u1086\'ee\u1088\'f0\u1084\'ec\u1072\'e0\u1094\'f6\u1080\'e8\u1080\'e8 \u1080\'e8 \u1087\'ef\u1086\'ee\u1083\'eb\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1100\'fc\u1102\'fe \u1089\'f1\u1086\'ee\u1089\'f1\u1088\'f0\u1077\'e5\u1076\'e4\u1086\'ee\u1090\'f2\u1086\'ee\u1095\'f7\u1077\'e5\u1085\'ed \u1085\'ed\u1072\'e0 \u1088\'f0\u1072\'e0\u1079\'e7\u1074\'e2\u1080\'e8\u1090\'f2\u1080\'e8\u1080\'e8 \u1089\'f1\u1091\'f3\u1073\'e1\u1098\'fa\u1077\'e5\u1082\'ea\u1090\'f2\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1080\'e8 \u1091\'f3\u1095\'f7\u1077\'e5\u1085\'ed\u1080\'e8\u1082\'ea\u1072\'e0\u187\'bb}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar

\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1058\'d2\u1077\'e5\u1084\'ec\u1072\'e0 \u8470\'b9 3 (\u1076\'e4\u1083\'eb\u1103\'ff \u1087\'ef\u1086\'ee\u1074\'e2\u1099\'fb\u1096\'f8\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff \u1082\'ea\u1074\'e2\u1072\'e0\u1083\'eb\u1080\'e8\u1092\'f4\u1080\'e8\u1082\'ea\u1072\'e0\u1094\'f6\u1080\'e8\u1080\'e8): }
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u171\'ab\u1055\'cf\u1088\'f0\u1086\'ee\u1075\'e3\u1088\'f0\u1072\'e0\u1084\'ec\u1084\'ec\u1072\'e0 \u1087\'ef\u1086\'ee\u1074\'e2\u1099\'fb\u1096\'f8\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff \u1082\'ea\u1074\'e2\u1072\'e0\u1083\'eb\u1080\'e8\u1092\'f4\u1080\'e8\u1082\'ea\u1072\'e0\u1094\'f6\u1080\'e8\u1080\'e8 \u8220\'93\u1059\'d3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc 2030: \u1086\'ee\u1090\'f2 \u1080\'e8\u1085\'ed\u1092\'f4\u1086\'ee\u1088\'f0\u1084\'ec\u1072\'e0\u1094\'f6\u1080\'e8\u1086\'ee\u1085\'ed\u1085\'ed\u1086\'ee\u1075\'e3\u1086\'ee \u1088\'f0\u1072\'e0\u1073\'e1\u1086\'ee\u1090\'f2\u1085\'ed\u1080\'e8\u1082\'ea\u1072\'e0 \u1082\'ea \u1086\'ee\u1088\'f0\u1075\'e3\u1072\'e0\u1085\'ed\u1080\'e8\u1079\'e7\u1072\'e0\u1090\'f2\u1086\'ee\u1088\'f0\u1091\'f3 \u1088\'f0\u1072\'e0\u1079\'e7\u1074\'e2\u1080\'e8\u1074\'e2\u1072\'e0\u1102\'fe\u1097\'f9\u1077\'e5\u1081\'e9 \u1076\'e4\u1077\'e5\u1103\'ff\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1080\'e8\u8221\'94 (32 \u1095\'f7\u1072\'e0\u1089\'f1\u1072\'e0, 25 \u1087\'ef\u1077\'e5\u1076\'e4\u1072\'e0\u1075\'e3\u1086\'ee\u1075\'e3\u1086\'ee\u1074\'e2 \u1075\'e3\u1080\'e8\u1084\'ec\u1085\'ed\u1072\'e0\u1079\'e7\u1080\'e8\u1080\'e8 \u1044\'c4\u1072\'e0\u1074\'e2\u1099\'fb\u1076\'e4\u1086\'ee\u1074\'e2\u1072\'e0)\u187\'bb}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar

