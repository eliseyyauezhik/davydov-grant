\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
- \u1080\'e8\u1076\'e4\u1077\'e5\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee \u1083\'eb\u1086\'ee\u1078\'e6\u1072\'e0\u1090\'f2\u1089\'f1\u1103\'ff \u1087\'ef\u1086\'ee\u1076\'e4 \u1087\'ef\u1086\'ee\u1088\'f0\u1091\'f3\u1095\'f7\u1077\'e5\u1085\'ed\u1080\'e8\u1077\'e5 \u1055\'cf\u1088\'f0\u1077\'e5\u1079\'e7\u1080\'e8\u1076\'e4\u1077\'e5\u1085\'ed\u1090\'f2\u1072\'e0 \u1080\'e8 \u1085\'ed\u1072\'e0\u1094\'f6\u1087\'ef\u1088\'f0\u1086\'ee\u1077\'e5\u1082\'ea\u1090\'f2 (\u1087\'ef\u1086\'ee\u1074\'e2\u1099\'fb\u1096\'f8\u1077\'e5\u1085\'ed\u1080\'e8\u1077\'e5 \u1082\'ea\u1074\'e2\u1072\'e0\u1083\'eb\u1080\'e8\u1092\'f4\u1080\'e8\u1082\'ea\u1072\'e0\u1094\'f6\u1080\'e8\u1080\'e8 + \u1062\'d6\u1054\'ce\u1057\'d1 \u171\'ab\u1052\'cc\u1086\'ee\u1103\'ff \u1096\'f8\u1082\'ea\u1086\'ee\u1083\'eb\u1072\'e0\u187\'bb);}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
