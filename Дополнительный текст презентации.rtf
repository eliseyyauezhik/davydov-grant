\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1042\'c2\u1099\'fb \u1086\'ee\u1087\'ef\u1080\'e8\u1089\'f1\u1072\'e0\u1083\'eb\u1080\'e8 \u1080\'e8\u1076\'e4\u1077\'e5\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1099\'fb\u1081\'e9 \u1089\'f1\u1094\'f6\u1077\'e5\u1085\'ed\u1072\'e0\u1088\'f0\u1080\'e8\u1081\'e9 2028\u8211\'962030 \u1075\'e3\u1086\'ee\u1076\'e4\u1086\'ee\u1074\'e2: \u1085\'ed\u1072\'e0\u1094\'f6\u1080\'e8\u1086\'ee\u1085\'ed\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1072\'e0\u1103\'ff \u1048\'c8\u1048\'c8-\u1089\'f1\u1080\'e8\u1089\'f1\u1090\'f2\u1077\'e5\u1084\'ec\u1072\'e0 + \u1074\'e2\u1072\'e0\u1096\'f8 \u1048\'c8\u1048\'c8-\u1090\'f2\u1100\'fc\u1102\'fe\u1090\'f2\u1086\'ee\u1088\'f0 (\u1089\'f1\u1086\'ee\u1086\'ee\u1090\'f2\u1074\'e2\u1077\'e5\u1090\'f2\u1089\'f1\u1090\'f2\u1074\'e2\u1091\'f3\u1102\'fe\u1097\'f9\u1080\'e8\u1081\'e9 \u1060\'d4\u1043\'c3\u1054\'ce\u1057\'d1) \u1084\'ec\u1075\'e3\u1085\'ed\u1086\'ee\u1074\'e2\u1077\'e5\u1085\'ed\u1085\'ed\u1086\'ee \u1074\'e2\u1099\'fb\u1087\'ef\u1086\'ee\u1083\'eb\u1085\'ed\u1103\'ff\u1102\'fe\u1090\'f2 \u1074\'e2\u1089\'f1\u1102\'fe \u1080\'e8\u1085\'ed\u1092\'f4\u1086\'ee\u1088\'f0\u1084\'ec\u1072\'e0\u1094\'f6\u1080\'e8\u1086\'ee\u1085\'ed\u1085\'ed\u1091\'f3\u1102\'fe \u1088\'f0\u1072\'e0\u1073\'e1\u1086\'ee\u1090\'f2\u1091\'f3 \u1091\'f3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1103\'ff. \u1059\'d3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc \u1074\'e2 \u1083\'eb\u1102\'fe\u1073\'e1\u1086\'ee\u1081\'e9 \u1084\'ec\u1086\'ee\u1084\'ec\u1077\'e5\u1085\'ed\u1090\'f2 \u1075\'e3\u1086\'ee\u1074\'e2\u1086\'ee\u1088\'f0\u1080\'e8\u1090\'f2: \u171\'ab\u1057\'d1\u1076\'e4\u1077\'e5\u1083\'eb\u1072\'e0\u1081\'e9 \u1084\'ec\u1085\'ed\u1077\'e5 \u1084\'ec\u1072\'e0\u1090\'f2\u1077\'e5\u1088\'f0\u1080\'e8\u1072\'e0\u1083\'eb \u1087\'ef\u1086\'ee \u1090\'f2\u1077\'e5\u1084\'ec\u1077\'e5 + 3 \u1091\'f3\u1088\'f0\u1086\'ee\u1074\'e2\u1085\'ed\u1103\'ff \u1079\'e7\u1072\'e0\u1076\'e4\u1072\'e0\u1085\'ed\u1080\'e8\u1081\'e9 + \u1074\'e2\u1080\'e8\u1076\'e4\u1077\'e5\u1086\'ee-\u1072\'e0\u1085\'ed\u1080\'e8\u1084\'ec\u1072\'e0\u1094\'f6\u1080\'e8\u1102\'fe + \u1088\'f0\u1072\'e0\u1089\'f1\u1089\'f1\u1099\'fb\u1083\'eb\u1082\'ea\u1091\'f3 \u1087\'ef\u1088\'f0\u1080\'e8\u1075\'e3\u1083\'eb\u1072\'e0\u1096\'f8\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff \u1085\'ed\u1072\'e0 \u1082\'ea\u1088\'f0\u1091\'f3\u1078\'e6\u1086\'ee\u1082\'ea\u187\'bb \u8212\'97 \u1080\'e8 \u1095\'f7\u1077\'e5\u1088\'f0\u1077\'e5\u1079\'e7 8 \u1089\'f1\u1077\'e5\u1082\'ea\u1091\'f3\u1085\'ed\u1076\'e4 \u1074\'e2\u1089\'f1\u1105\'b8 \u1075\'e3\u1086\'ee\u1090\'f2\u1086\'ee\u1074\'e2\u1086\'ee. \u1054\'ce\u1090\'f2\u1095\'f7\u1105\'b8\u1090\'f2\u1099\'fb, \u1087\'ef\u1083\'eb\u1072\'e0\u1085\'ed\u1099\'fb, \u1087\'ef\u1088\'f0\u1086\'ee\u1074\'e2\u1077\'e5\u1088\'f0\u1082\'ea\u1072\'e0, \u1080\'e8\u1085\'ed\u1076\'e4\u1080\'e8\u1074\'e2\u1080\'e8\u1076\'e4\u1091\'f3\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1099\'fb\u1077\'e5 \u1090\'f2\u1088\'f0\u1072\'e0\u1077\'e5\u1082\'ea\u1090\'f2\u1086\'ee\u1088\'f0\u1080\'e8\u1080\'e8 \u8212\'97 \u1074\'e2\u1089\'f1\u1105\'b8 \u1091\'f3\u1093\'f5\u1086\'ee\u1076\'e4\u1080\'e8\u1090\'f2 \u1074\'e2 \u1048\'c8\u1048\'c8.}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar

\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1058\'d2\u1086\'ee\u1075\'e3\u1076\'e4\u1072\'e0 \u1095\'f7\u1090\'f2\u1086\'ee \u1086\'ee\u1089\'f1\u1090\'f2\u1072\'e0\u1105\'b8\u1090\'f2\u1089\'f1\u1103\'ff \u1091\'f3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1102\'fe?}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1063\'d7\u1090\'f2\u1086\'ee \u1089\'f1\u1090\'f2\u1072\'e0\u1085\'ed\u1086\'ee\u1074\'e2\u1080\'e8\u1090\'f2\u1089\'f1\u1103\'ff \u1075\'e3\u1083\'eb\u1072\'e0\u1074\'e2\u1085\'ed\u1099\'fb\u1084\'ec \u1087\'ef\u1088\'f0\u1077\'e5\u1076\'e4\u1084\'ec\u1077\'e5\u1090\'f2\u1086\'ee\u1084\'ec \u1077\'e5\u1075\'e3\u1086\'ee \u1074\'e2\u1085\'ed\u1080\'e8\u1084\'ec\u1072\'e0\u1085\'ed\u1080\'e8\u1103\'ff \u1080\'e8 \u1076\'e4\u1077\'e5\u1103\'ff\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1080\'e8?}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar

\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
### \u1050\'ca\u1086\'ee\u1088\'f0\u1086\'ee\u1090\'f2\u1082\'ea\u1080\'e8\u1081\'e9 \u1086\'ee\u1090\'f2\u1074\'e2\u1077\'e5\u1090\'f2 (\u1103\'ff\u1076\'e4\u1088\'f0\u1086\'ee):}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1042\'c2\u1089\'f1\u1105\'b8, \u1095\'f7\u1090\'f2\u1086\'ee \u1089\'f1\u1074\'e2\u1103\'ff\u1079\'e7\u1072\'e0\u1085\'ed\u1086\'ee \u1089\'f1 \u1095\'f7\u1077\'e5\u1083\'eb\u1086\'ee\u1074\'e2\u1077\'e5\u1095\'f7\u1077\'e5\u1089\'f1\u1082\'ea\u1086\'ee\u1081\'e9 \u1089\'f1\u1091\'f3\u1073\'e1\u1098\'fa\u1077\'e5\u1082\'ea\u1090\'f2\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1100\'fc\u1102\'fe, \u1089\'f1\u1084\'ec\u1099\'fb\u1089\'f1\u1083\'eb\u1086\'ee\u1084\'ec, \u1086\'ee\u1090\'f2\u1085\'ed\u1086\'ee\u1096\'f8\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff\u1084\'ec\u1080\'e8 \u1080\'e8 \u1088\'f0\u1072\'e0\u1079\'e7\u1074\'e2\u1080\'e8\u1090\'f2\u1080\'e8\u1077\'e5\u1084\'ec \u1084\'ec\u1099\'fb\u1096\'f8\u1083\'eb\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff \u1082\'ea\u1072\'e0\u1082\'ea \u1076\'e4\u1077\'e5\u1103\'ff\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1080\'e8.}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar

\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
\u1045\'c5\u1089\'f1\u1083\'eb\u1080\'e8 \u1091\'f3\u1073\'e1\u1088\'f0\u1072\'e0\u1090\'f2\u1100\'fc \u1072\'e0\u1073\'e1\u1089\'f1\u1086\'ee\u1083\'eb\u1102\'fe\u1090\'f2\u1085\'ed\u1086\'ee \u1074\'e2\u1089\'f1\u1102\'fe \u1086\'ee\u1073\'e1\u1088\'f0\u1072\'e0\u1073\'e1\u1086\'ee\u1090\'f2\u1082\'ea\u1091\'f3 \u1080\'e8\u1085\'ed\u1092\'f4\u1086\'ee\u1088\'f0\u1084\'ec\u1072\'e0\u1094\'f6\u1080\'e8\u1080\'e8, \u1091\'f3 \u1091\'f3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1103\'ff \u1086\'ee\u1089\'f1\u1090\'f2\u1072\'e0\u1105\'b8\u1090\'f2\u1089\'f1\u1103\'ff \u1089\'f1\u1072\'e0\u1084\'ec\u1086\'ee\u1077\'e5 \u1076\'e4\u1086\'ee\u1088\'f0\u1086\'ee\u1075\'e3\u1086\'ee\u1077\'e5 \u1080\'e8 \u1089\'f1\u1072\'e0\u1084\'ec\u1086\'ee\u1077\'e5 \u1090\'f2\u1088\'f0\u1091\'f3\u1076\'e4\u1085\'ed\u1086\'ee\u1077\'e5 \u8212\'97 \u1090\'f2\u1086\'ee, \u1095\'f7\u1090\'f2\u1086\'ee \u1048\'c8\u1048\'c8 \u1087\'ef\u1088\'f0\u1080\'e8\u1085\'ed\u1094\'f6\u1080\'e8\u1087\'ef\u1080\'e8\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee \u1085\'ed\u1077\'e5 \u1084\'ec\u1086\'ee\u1078\'e6\u1077\'e5\u1090\'f2 \u1076\'e4\u1077\'e5\u1083\'eb\u1072\'e0\u1090\'f2\u1100\'fc, \u1087\'ef\u1086\'ee\u1090\'f2\u1086\'ee\u1084\'ec\u1091\'f3 \u1095\'f7\u1090\'f2\u1086\'ee \u1091\'f3 \u1085\'ed\u1077\'e5\u1075\'e3\u1086\'ee \u1085\'ed\u1077\'e5\u1090\'f2 \u171\'ab\u1103\'ff\u187\'bb, \u1085\'ed\u1077\'e5\u1090\'f2 \u1087\'ef\u1077\'e5\u1088\'f0\u1077\'e5\u1078\'e6\u1080\'e8\u1074\'e2\u1072\'e0\u1085\'ed\u1080\'e8\u1103\'ff, \u1085\'ed\u1077\'e5\u1090\'f2 \u1086\'ee\u1090\'f2\u1074\'e2\u1077\'e5\u1090\'f2\u1089\'f1\u1090\'f2\u1074\'e2\u1077\'e5\u1085\'ed\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1080\'e8 \u1087\'ef\u1077\'e5\u1088\'f0\u1077\'e5\u1076\'e4 \u1078\'e6\u1080\'e8\u1074\'e2\u1099\'fb\u1084\'ec \u1088\'f0\u1077\'e5\u1073\'e1\u1105\'b8\u1085\'ed\u1082\'ea\u1086\'ee\u1084\'ec.}
\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar

\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
### \u1063\'d7\u1090\'f2\u1086\'ee \u1080\'e8\u1084\'ec\u1077\'e5\u1085\'ed\u1085\'ed\u1086\'ee \u1086\'ee\u1089\'f1\u1090\'f2\u1072\'e0\u1105\'b8\u1090\'f2\u1089\'f1\u1103\'ff (\u1082\'ea\u1086\'ee\u1085\'ed\u1082\'ea\u1088\'f0\u1077\'e5\u1090\'f2\u1085\'ed\u1099\'fb\u1077\'e5 \u1092\'f4\u1091\'f3\u1085\'ed\u1082\'ea\u1094\'f6\u1080\'e8\u1080\'e8 \u1080\'e8 \u1082\'ea\u1077\'e5\u1081\'e9\u1089\'f1\u1099\'fb)}
