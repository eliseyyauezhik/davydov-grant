\par \pard\plain \s16\sl276\slmult1\sb0\sa140\fi0\li0\lin0\ri0\rin0\ltrpar{
| \u1063\'d7\u1090\'f2\u1086\'ee \u1048\'c8\u1048\'c8 \u1079\'e7\u1072\'e0\u1073\'e1\u1088\'f0\u1072\'e0\u1083\'eb \u1085\'ed\u1072\'e0\u1074\'e2\u1089\'f1\u1077\'e5\u1075\'e3\u1076\'e4\u1072\'e0 | \u1063\'d7\u1090\'f2\u1086\'ee \u1086\'ee\u1089\'f1\u1090\'f2\u1072\'e0\u1105\'b8\u1090\'f2\u1089\'f1\u1103\'ff \u1090\'f2\u1086\'ee\u1083\'eb\u1100\'fc\u1082\'ea\u1086\'ee \u1091\'f3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1102\'fe (\u1080\'e8 \u1096\'f8\u1082\'ea\u1086\'ee\u1083\'eb\u1077\'e5) | \u1050\'ca\u1086\'ee\u1085\'ed\u1082\'ea\u1088\'f0\u1077\'e5\u1090\'f2\u1085\'ed\u1099\'fb\u1081\'e9 \u1082\'ea\u1077\'e5\u1081\'e9\u1089\'f1 \u1074\'e2 \u1075\'e3\u1080\'e8\u1084\'ec\u1085\'ed\u1072\'e0\u1079\'e7\u1080\'e8\u1080\'e8 \u1044\'c4\u1072\'e0\u1074\'e2\u1099\'fb\u1076\'e4\u1086\'ee\u1074\'e2\u1072\'e0 |}
